        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d-%m-%y}",
	"format": "пАЧ {:%I:%M %p}"

    },
    "cpu": {
        "format": "у∞ї† {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "у∞НЫ {}%"
    },
    "temperature": {
