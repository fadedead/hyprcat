{
    "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    "margin-top": 6,
    "margin-left": 4,
    "margin-right": 4,
    "margin-bottom": 2,
    // Choose the order of the modules
    "modules-left": ["custom/media"],
    "modules-center": ["wlr/workspaces"],
    "modules-right": ["pulseaudio", "cpu", "memory", "temperature", "battery", "battery#bat2", "clock", "tray"],

    "wlr/workspaces": {
    	"all-outputs": true,
        "on-click": "activate",
	"format": "{icon}",
	"format-icons": {
	"avaliable": "пЖТ",
	"default": "у±УЉ",
	"active" : "у±Уї"
	}
     }, 
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пА£",
            "unlocked": "пВЬ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "пЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
